    "source": {
      "type": "github",
      "repo": "codezombiech/vscode-gitignore"
    },
    "url": "https://github.com/codezombiech/vscode-gitignore",
    "languages": ["gitignore"],
    "categories": ["Other"],
    "minPluginVersion": "1.2.2",
    "convert": [
      {
        "type": "source",
        "transforms": ["import-mapping"],
