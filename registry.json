  {
    "name": "biome",
    "displayName": "Biome",
    "description": "Linter and formatter for JS/TS/CSS/JSON — one tool, fast",
    "type": "pure-lsp",
    "source": {
      "type": "github",
      "repo": "biomejs/biome-vscode"
    },
    "url": "https://github.com/biomejs/biome-vscode",
    "languages": ["javascript", "typescript", "javascriptreact", "typescriptreact", "json", "jsonc", "css", "html", "vue", "svelte", "astro", "xml", "graphql"],
    "categories": ["LSP", "Linter", "Formatter"],
    "minPluginVersion": "1.2.2",
    "serverBinary": {
      "repo": "biomejs/biome",
      "asset": "biome-{{platform}}-{{arch}}",
      "binaryPath": "biome",
      "args": ["lsp-proxy"]
    },
    "convert": [
      {
        "type": "language-client",
        "server": {
          "kind": "binary",
          "package": "biome",
          "binary": {
            "repo": "biomejs/biome",
            "asset": "biome-{{platform}}-{{arch}}",
            "binaryPath": "biome"
          },
          "args": ["lsp-proxy"]
        },
        "transport": "stdio",
        "languages": ["javascript", "typescript", "javascriptreact", "typescriptreact", "json", "jsonc", "css", "html", "vue", "svelte", "astro", "xml", "graphql"]
      },
      {
        "type": "source",
        "transforms": ["import-mapping"]
      }
    ]
  },
