[
  {
    "name": "volar",
    "displayName": "Volar (Vue)",
    "description": "Vue language support — template/script/style IntelliSense",
    "type": "ts-bridge",
    "source": {
      "type": "github",
      "repo": "vuejs/language-tools",
      "subdir": "extensions/vscode"
    },
    "url": "https://github.com/vuejs/language-tools",
    "languages": [
      "vue"
    ],
    "categories": [
      "LSP",
      "TypeScript"
    ],
    "minPluginVersion": "1.2.0",
    "convert": [
      {
        "type": "bridge",
        "preset": "ts-bridge"
      },
      {
        "type": "language-client",
        "server": {
          "kind": "module",
          "package": "@vue/language-server",
          "entry": "main"
        },
        "languages": [
          "vue"
        ]
      },
      {
        "type": "source",
        "transforms": [
          "import-mapping",
          "strip-volar"
        ]
      }
    ]
  },
  {
    "name": "prisma",
    "displayName": "Prisma",
    "description": "Prisma schema language support — syntax highlight, lint, format",
    "type": "pure-lsp",
    "source": {
      "type": "github",
      "repo": "prisma/language-tools",
      "subdir": "packages/vscode"
    },
    "url": "https://github.com/prisma/language-tools",
    "languages": [
      "prisma"
    ],
    "categories": [
      "LSP"
    ],
    "minPluginVersion": "1.2.0",
    "convert": [
      {
        "type": "language-client",
        "server": {
          "kind": "module",
          "package": "@prisma/language-server",
          "entry": "bin"
        },
        "languages": [
          "prisma"
        ]
      },
      {
        "type": "source",
        "transforms": [
          "import-mapping",
          "enum-offset"
        ],
        "entry": "src/extension.ts",
        "keepDeps": [
          "@hono/node-server",
          "prisma-6-language-server"
        ]
      }
    ]
  },
  {
    "name": "html-css-support",
    "displayName": "HTML CSS Support",
    "description": "CSS class name completion for HTML attributes",
    "type": "direct-api",
    "source": {
      "type": "github",
      "repo": "ecmel/vscode-html-css"
    },
    "url": "https://github.com/ecmel/vscode-html-css",
    "languages": [
      "html",
      "css"
    ],
    "categories": [
      "Completion"
    ],
    "minPluginVersion": "1.2.0",
    "convert": [
      {
        "type": "source",
        "transforms": [
          "import-mapping",
          "class-to-factory",
          "provider-register"
        ],
        "entry": "src/extension.ts",
        "activationEvents": [
          "onLanguage:html",
          "onLanguage:css"
        ],
        "verbose": true
      }
    ]
  },
  {
    "name": "lua",
    "displayName": "Lua",
    "description": "Lua language support — completion, lint, and type checking",
    "type": "pure-lsp",
    "source": {
      "type": "github",
      "repo": "sumneko/vscode-lua",
      "subdir": "client"
    },
    "url": "https://github.com/sumneko/vscode-lua",
    "languages": [
      "lua"
    ],
    "categories": [
      "LSP"
    ],
    "serverBinary": {
      "repo": "LuaLS/lua-language-server",
      "asset": "lua-language-server-{{version}}-{{platform}}-{{arch}}.tar.gz",
      "binaryPath": "bin/lua-language-server"
    },
    "minPluginVersion": "1.2.0",
    "convert": [
      {
        "type": "language-client",
        "server": {
          "kind": "binary",
          "package": "lua",
          "binary": {
            "repo": "LuaLS/lua-language-server",
            "asset": "lua-language-server-{{version}}-{{platform}}-{{arch}}.tar.gz",
            "binaryPath": "bin/lua-language-server"
          }
        },
        "languages": [
          "lua"
        ]
      },
      {
        "type": "source",
        "transforms": [
          "import-mapping"
        ]
      }
    ]
  },
