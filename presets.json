{
  "ts-bridge": {
    "type": "tsserver-forward",
    "options": {
      "extensions": ["coc-tsserver"],
      "services": ["tsserver"],
      "command": "typescript.tsserverRequest"
    }
  },
  "prettier": {
    "type": "prettier",
    "options": {
      "languages": ["javascript", "typescript", "javascriptreact", "typescriptreact", "css", "html", "json", "yaml", "markdown", "scss", "less"]
    }
  }
}
